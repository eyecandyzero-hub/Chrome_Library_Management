{
  "manifest_version": 3,
  "name": "1.도서 목록 매칭 매니저",
  "version": "1.9",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting", "downloads", "cookies"],
  "host_permissions": [
    "*://*.gigafile.nu/*",
    "*://*.xgf.nu/*",
    "*://*.gofile.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "options.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}